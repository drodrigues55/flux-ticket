// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TicketStatus {
  PENDING_VALIDATION
  PENDING_PAYMENT
  VALID
  REVOKED
  CONSUMED
}

enum EventStatus {
  DRAFT
  READY_FOR_VALIDATION
  PUBLISHED
  SALES_OPEN
  LIVE
  FINISHED
  ARCHIVED
  CANCELLED
}

enum EventLocationType {
  PHYSICAL
  ONLINE
  HYBRID
}

enum TicketBatchStatus {
  PENDING
  ACTIVE
  COMPLETED
  PAUSED
}

enum BatchProgressionRule {
  QUANTITY_SOLD
  DATE_REACHED
  QUANTITY_OR_DATE
  QUANTITY_AND_DATE
  MANUAL
}

enum SalesChannel {
  ONLINE
  POS
  COMPLIMENTARY
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  REFUNDED
  CANCELLED
  FAILED
}

enum ReservationStatus {
  ACTIVE
  EXPIRED
  CONVERTED
  CANCELLED
  ABANDONED
}

enum OrderStatus {
  CREATED
  PROCESSING
  PAID
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum WaitlistStatus {
  WAITING
  INVITED
  RESERVED
  EXPIRED
  CANCELLED
}

enum AlertType {
  LOW_STOCK
  SLOW_SALES
  FAST_SALES
  CHECKIN_ISSUE
  REFUND_SPIKE
  MISSING_ASSET
  FINANCIAL_ISSUE
}

enum AlertSeverity {
  CRITICAL
  WARNING
  INFO
}

enum PayoutStatus {
  PENDING
  SCHEDULED
  PROCESSING
  SETTLED
  FAILED
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER") // USER, ORGANIZER, STAFF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets  Ticket[]
  events   Event[]   @relation("EventOrganizer")
  payments Payment[]
  payouts  Payout[]
  reservations Reservation[]
  orders Order[]
  waitlistEntries WaitlistEntry[]
}

model Event {
  id             String      @id @default(uuid())
  slug           String?
  title          String
  shortDescription String?
  description    String?
  date           DateTime
  endDate        DateTime?
  timezone       String?
  locationType   EventLocationType @default(PHYSICAL)
  location       String      // full address
  venue          String?     // display name (e.g. "Arena São Paulo")
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  country        String?
  onlineUrl      String?
  imageUrl       String?     // cover image URL
  categoryId     Int?
  capacityTarget Int?        // target occupancy % for alerts (default: 80)
  status         EventStatus @default(DRAFT)
  tags           String[]    @default([])
  organizerId    String
  organizer      User        @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  ticketTypes TicketType[]
  batches   TicketBatch[]
  tickets   Ticket[]
  payments  Payment[]
  reservations Reservation[]
  orders    Order[]
  waitlistEntries WaitlistEntry[]
  checkins Checkin[]
  saleLogs  SaleLog[]
  alerts    EventAlert[]
  snapshots DailySalesSnapshot[]
  payouts   Payout[]

  @@index([organizerId])
  @@unique([organizerId, slug])
  @@index([date])
  @@index([status])
}

model TicketType {
  id            String        @id @default(uuid())
  eventId       String
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  sectorId      Int?
  sectorName    String?
  capacity      Int
  visibility    Boolean       @default(true)
  transferable  Boolean       @default(true)
  refundable    Boolean       @default(true)
  purchaseLimit Int           @default(5)
  isActive      Boolean       @default(true)
  archivedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  batches       TicketBatch[]

  @@index([eventId])
}

model TicketBatch {
  id                String   @id @default(uuid())
  eventId           String
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypeId      String?
  ticketType        TicketType? @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  name              String
  price             Decimal
  totalQuantity     Int
  availableQuantity Int
  sectorId          Int?
  sectorName        String?
  meiaEntrada       Boolean  @default(false)
  isActive          Boolean  @default(true)
  
  salesStart        DateTime?
  salesEnd          DateTime?
  purchaseLimit     Int?
  status            TicketBatchStatus @default(PENDING)
  progressionRule   BatchProgressionRule @default(QUANTITY_OR_DATE)
  displayOrder      Int      @default(0)
  archivedAt        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tickets  Ticket[]
  saleLogs SaleLog[]
  reservationItems ReservationItem[]
  waitlistEntries WaitlistEntry[]

  @@index([eventId])
  @@index([ticketTypeId])
  @@index([status])
  @@index([displayOrder])
  @@index([eventId, isActive])
}

model Ticket {
  id            String       @id @default(uuid())
  // Direct FK to event (denormalized for dashboard query performance)
  eventId       String
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  batchId       String
  batch         TicketBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         User         @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  reservationItemId String?
  reservationItem   ReservationItem? @relation(fields: [reservationItemId], references: [id], onDelete: SetNull)
  orderId       String?
  order         Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  buyerCpf      String
  holderName    String?
  holderCpf     String?
  price         Decimal
  status        TicketStatus @default(PENDING_VALIDATION)
  channel       SalesChannel @default(ONLINE)
  meiaEntrada   Boolean      @default(false)
  isTransferred Boolean      @default(false)
  hmacSignature String?
  checkedInAt   DateTime?    // timestamp when status became CONSUMED
  refundedAt    DateTime?
  expiresAt     DateTime
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  payments Payment[]
  statusHistory TicketStatusHistory[]
  checkins Checkin[]

  // Performance indexes for dashboard aggregation queries
  @@index([eventId])
  @@index([eventId, status])
  @@index([eventId, status, createdAt])
  @@index([batchId])
  @@index([buyerId])
  @@index([reservationId])
  @@index([orderId])
  @@index([createdAt])
  @@index([status, createdAt])
}

model Payment {
  id                String        @id @default(uuid())
  eventId           String
  event             Event         @relation(fields: [eventId], references: [id])
  buyerId           String
  buyer             User          @relation(fields: [buyerId], references: [id])
  orderId           String?
  order             Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  method            PaymentMethod
  status            PaymentStatus
  amount            Decimal       // total amount in BRL
  installments      Int           @default(1)
  provider          String        // "MERCADO_PAGO" | "MOCK"
  providerPaymentId String?       // external payment ID (MP ID)
  providerStatus    String?
  providerEventId   String?
  idempotencyKey    String?
  rawPayload        Json?
  rawResponse       Json?         // full provider response for audit
  paidAt            DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tickets  Ticket[]
  saleLogs SaleLog[]

  @@index([eventId])
  @@index([buyerId])
  @@index([orderId])
  @@index([providerPaymentId])
  @@index([provider, providerPaymentId])
  @@index([providerEventId])
  @@index([idempotencyKey])
  @@index([status])
  @@index([eventId, status])
  @@index([createdAt])
}

model Reservation {
  id        String            @id @default(uuid())
  eventId   String
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User              @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  items   ReservationItem[]
  tickets Ticket[]
  orders  Order[]
  waitlistEntries WaitlistEntry[]

  @@index([eventId])
  @@index([buyerId])
  @@index([status, expiresAt])
  @@index([createdAt])
}

model ReservationItem {
  id            String      @id @default(uuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  batchId       String
  batch         TicketBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  quantity      Int
  unitPrice     Decimal
  createdAt     DateTime    @default(now())

  tickets Ticket[]

  @@index([reservationId])
  @@index([batchId])
}

model Order {
  id            String      @id @default(uuid())
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  eventId       String
  event         Event       @relation(fields: [eventId], references: [id])
  buyerId       String
  buyer         User        @relation(fields: [buyerId], references: [id])
  status        OrderStatus @default(CREATED)
  grossAmount   Decimal
  discountAmount Decimal    @default(0)
  netAmount     Decimal
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tickets  Ticket[]
  payments Payment[]

  @@index([reservationId])
  @@index([eventId])
  @@index([buyerId])
  @@index([status, createdAt])
}

model WaitlistEntry {
  id            String         @id @default(uuid())
  eventId       String
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  batchId       String
  batch         TicketBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  buyerId       String?
  buyer         User?          @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  reservationId String?
  reservation   Reservation?   @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  email         String
  name          String?
  phone         String?
  status        WaitlistStatus @default(WAITING)
  position      Int
  expiresAt     DateTime?
  invitedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([eventId])
  @@index([batchId, status, position])
  @@index([email])
  @@index([expiresAt])
}

model TicketStatusHistory {
  id         String       @id @default(uuid())
  ticketId   String
  ticket     Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromStatus TicketStatus?
  toStatus   TicketStatus
  reason     String?
  actorId    String?
  requestId  String?
  metadata   Json?
  createdAt  DateTime     @default(now())

  @@index([ticketId, createdAt])
  @@index([toStatus])
  @@index([requestId])
}

model Checkin {
  id             String   @id @default(uuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketId       String?
  ticket         Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  offlineId      String?
  deviceId       String?
  deviceName     String?
  operatorId     String?
  sectorId       Int?
  status         String   @default("ACCEPTED") // ACCEPTED, DUPLICATE, CONFLICT, REJECTED
  conflictReason String?
  scannedAt      DateTime @default(now())
  syncedAt       DateTime @default(now())
  requestId      String?
  rawPayload     Json?
  createdAt      DateTime @default(now())

  @@unique([eventId, offlineId])
  @@index([eventId, ticketId])
  @@index([ticketId, status])
  @@index([eventId, status, syncedAt])
  @@index([deviceId, syncedAt])
  @@index([requestId])
}

/// Business-level audit trail: one record per ticket sold.
/// Used by dashboard Recent Sales feed and financial reports.
model SaleLog {
  id          String        @id @default(uuid())
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id])
  ticketId    String
  batchId     String
  batch       TicketBatch   @relation(fields: [batchId], references: [id])
  paymentId   String?
  payment     Payment?      @relation(fields: [paymentId], references: [id])
  buyerName   String
  buyerEmail  String
  holderName  String?
  batchName   String
  eventTitle  String
  price       Decimal
  channel     SalesChannel
  method      PaymentMethod?
  status      TicketStatus
  occurredAt  DateTime      @default(now())

  @@index([eventId, occurredAt])
  @@index([eventId, status])
  @@index([occurredAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  metadata   Json?
  reason     String?
  requestId  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([action])
  @@index([requestId])
  @@index([createdAt])
}

/// Pre-aggregated daily revenue and ticket counts per event.
/// Feeds the sales history chart without expensive real-time aggregations.
model DailySalesSnapshot {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date        DateTime // day-truncated UTC (midnight)
  revenue     Decimal  @default(0)
  ticketsSold Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([eventId, date])
  @@index([eventId, date])
}

/// Event-level operational alerts surfaced by the dashboard intelligence layer.
model EventAlert {
  id              String        @id @default(uuid())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type            AlertType
  severity        AlertSeverity
  message         String
  suggestedAction String?
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())

  @@index([eventId, resolvedAt])
  @@index([severity])
}

/// Scheduled and settled financial payouts to organizers.
model Payout {
  id            String       @id @default(uuid())
  organizerId   String
  organizer     User         @relation(fields: [organizerId], references: [id])
  eventId       String?
  event         Event?       @relation(fields: [eventId], references: [id])
  amount        Decimal
  status        PayoutStatus
  scheduledDate DateTime?
  settledAt     DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([organizerId, status])
  @@index([eventId])
  @@index([scheduledDate])
}

/// Infrastructure-level outbox for eventual consistency delivery.
/// Separate from SaleLog (business audit). Do not remove.
model OutboxEvent {
  id            String   @id @default(uuid())
  aggregateType String
  aggregateId   String
  type          String?
  payload       Json
  status        String   @default("PENDING") // PENDING, PROCESSED
  attempts      Int      @default(0)
  nextRunAt     DateTime?
  processedAt   DateTime?
  requestId     String?
  createdAt     DateTime @default(now())

  @@index([status])
  @@index([type])
  @@index([status, nextRunAt])
  @@index([requestId])
}
