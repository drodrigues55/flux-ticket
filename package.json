{
  "name": "flux-tickets",
  "version": "1.0.0",
  "description": "Flux Project Monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "concurrently --kill-others -p \"[{name}]\" -n \"PWA,DASH,READ,WRITE,CLIENT,WORK\" -c \"cyan,magenta,yellow,green,blue,red\" \"npm run dev -w @flux/staff-pwa\" \"npm run dev -w @flux/dashboard\" \"npm run dev -w @flux/api-read\" \"npm run dev -w @flux/api-write\" \"npm run dev -w @flux/client\" \"npm run dev -w @flux/ticket-worker\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "smoke:observability": "tsx scripts/smoke-observability-compat.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.15",
    "prisma": "^5.10.2",
    "tailwindcss": "^3.4.1",
    "turbo": "^2.9.18",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "ajv": "8.20.0",
    "express-rate-limit": {
      "express": "4.22.2"
    },
    "file-type": "22.0.1",
    "glob": "13.0.6",
    "multer": "2.2.0",
    "picomatch": "4.0.4",
    "qs": "6.15.2",
    "tmp": "0.2.7",
    "webpack": "5.107.2"
  }
}
