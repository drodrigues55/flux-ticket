# System Environment Configuration
APP_ENV="production"
NODE_ENV="production"
SERVICE_VERSION="1.0.0"
GIT_COMMIT="hash-here"

# Database Configuration
DATABASE_URL="postgresql://db_user:db_password@db_host:5432/flux_ticket?schema=public"

# Cache and Message Broker
REDIS_URL="redis://:redis_password@redis_host:6379"
REDIS_HOST="redis_host"
REDIS_PORT="6379"

# Security Credentials
JWT_SECRET="replace-with-production-high-entropy-jwt-secret-at-least-32-chars"
HMAC_SECRET="replace-with-production-high-entropy-hmac-secret-at-least-32-chars"
HMAC_SECRET_KEY="replace-with-production-high-entropy-hmac-secret-at-least-32-chars"
TICKET_HMAC_SECRET="replace-with-production-high-entropy-hmac-secret-at-least-32-chars"

# Observability
LOG_LEVEL="info"
PROMETHEUS_ENABLED="true"
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
SENTRY_RELEASE="1.0.0"

# Provider Integrations
PAYMENT_PROVIDER="MOCK"
MERCADO_PAGO_ACCESS_TOKEN="replace-with-mercado-pago-access-token"
MERCADO_PAGO_PUBLIC_KEY="replace-with-mercado-pago-public-key"
MERCADO_PAGO_WEBHOOK_SECRET="replace-with-mercado-pago-webhook-secret"
MERCADO_PAGO_WEBHOOK_URL="https://api.fluxtickets.com/webhooks/mercado-pago"

EMAIL_PROVIDER="RESEND"
RESEND_API_KEY=""
MAIL_FROM="Flux Tickets <noreply@fluxtickets.com>"

WHATSAPP_PROVIDER="MOCK"

# Apple & Google Wallet Preparation Keys
APPLE_WALLET_TEAM_ID="FLUX123456"
APPLE_PASS_TYPE_ID="pass.com.fluxtickets"
APPLE_CERT_PATH=""
APPLE_CERT_PASSWORD=""

GOOGLE_WALLET_ISSUER_ID="issuer_id_here"
GOOGLE_WALLET_CREDENTIALS_PATH=""

# Service Endpoints
API_WRITE_URL="http://localhost:4000"
API_READ_URL="http://localhost:3002"

